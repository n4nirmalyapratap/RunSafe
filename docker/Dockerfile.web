# syntax=docker/dockerfile:1.7

# ─── Stage 1: install workspace dependencies ────────────────────────────────
FROM node:24-alpine AS deps
WORKDIR /repo

RUN apk add --no-cache libc6-compat \
 && corepack enable \
 && corepack prepare pnpm@10.26.1 --activate

COPY pnpm-workspace.yaml pnpm-lock.yaml package.json .npmrc ./
COPY tsconfig.base.json tsconfig.json ./
COPY artifacts/api-server/package.json artifacts/api-server/
COPY artifacts/runsafe/package.json artifacts/runsafe/
COPY artifacts/runsafe-pitch/package.json artifacts/runsafe-pitch/
COPY artifacts/mockup-sandbox/package.json artifacts/mockup-sandbox/
COPY lib/api-spec/package.json lib/api-spec/
COPY lib/api-zod/package.json lib/api-zod/
COPY lib/api-client-react/package.json lib/api-client-react/
COPY lib/db/package.json lib/db/
COPY scripts/package.json scripts/

RUN --mount=type=cache,id=pnpm-store,target=/root/.local/share/pnpm/store \
    pnpm install --frozen-lockfile

# ─── Stage 2: build the React/Vite SPA ──────────────────────────────────────
FROM deps AS build
WORKDIR /repo
COPY . .

# VITE_CLERK_PUBLISHABLE_KEY is baked in at build time (Vite inlines env vars).
ARG VITE_CLERK_PUBLISHABLE_KEY
ARG BASE_PATH=/
ARG PORT=4173
ENV VITE_CLERK_PUBLISHABLE_KEY=${VITE_CLERK_PUBLISHABLE_KEY} \
    BASE_PATH=${BASE_PATH} \
    PORT=${PORT}

RUN pnpm --filter @workspace/api-spec run codegen \
 && pnpm --filter @workspace/runsafe run build

# ─── Stage 3: nginx static server with SPA fallback + /api proxy ────────────
FROM nginx:1.27-alpine AS runtime
COPY docker/nginx.conf /etc/nginx/conf.d/default.conf
COPY --from=build /repo/artifacts/runsafe/dist /usr/share/nginx/html

EXPOSE 80
CMD ["nginx", "-g", "daemon off;"]
