# ─── Postgres ───────────────────────────────────────────────────────────────
POSTGRES_USER=runsafe
POSTGRES_PASSWORD=change-me-in-production
POSTGRES_DB=runsafe
DB_PORT=5432

# ─── Clerk (auth) ───────────────────────────────────────────────────────────
# Server-side secret. Required by the api container.
CLERK_SECRET_KEY=sk_test_xxx
# Public key — baked into the SPA bundle at build time.
VITE_CLERK_PUBLISHABLE_KEY=pk_test_xxx

# ─── SendGrid (optional, compliance email reminders) ────────────────────────
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=

# ─── Web ────────────────────────────────────────────────────────────────────
# Host port to publish the nginx container on.
WEB_PORT=8000
